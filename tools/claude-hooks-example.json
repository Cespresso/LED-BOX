{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/led-box/tools/.venv/bin/python3 /path/to/led-box/tools/ble-notify.py waiting"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/led-box/tools/.venv/bin/python3 /path/to/led-box/tools/ble-notify.py complete"
          }
        ]
      }
    ]
  }
}
